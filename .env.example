# ============================================================
# Supabase — preencha com o SEU projeto (supabase.com/dashboard)
# Settings → API → Project URL + anon public + service_role
# ============================================================
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_public_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Web Push (opcional — configurar depois)
VITE_VAPID_PUBLIC_KEY=

# Google Calendar OAuth (opcional — configurar depois)
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
