# ============================================================
# MIGRAÇÃO LOCAL — NÃO COMMITAR (.env.migration)
# Copie para .env.migration e preencha UMA VEZ.
# Após importar, rode: npm run migrate:cleanup
# ============================================================

# --- Origem (projeto antigo — só para exportar) ---
SOURCE_SUPABASE_URL=https://PROJETO_ANTIGO.supabase.co
SOURCE_SERVICE_ROLE_KEY=sua_service_role_do_projeto_antigo

# Connection string Postgres (Settings → Database → URI)
# Necessário para clonar o SCHEMA (estrutura das tabelas)
SOURCE_DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- Destino (seu KAIZEN — pode repetir o .env principal) ---
TARGET_SUPABASE_URL=https://vpcdbrzpxhhykupjdwti.supabase.co
TARGET_SERVICE_ROLE_KEY=sua_service_role_kaizen

TARGET_DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
